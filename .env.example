# Application
APP_NAME=event-analytics-api
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# Security
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
BCRYPT_ROUNDS=12

# Database
DATABASE_URL=postgresql+asyncpg://events:events@postgres:5432/events
DATABASE_URL_SYNC=postgresql://events:events@postgres:5432/events

# Redis
REDIS_URL=redis://redis:6379/0

# Ingest
INGEST_MODE=async
EVENT_STREAM_NAME=stream:events
EVENT_DLQ_STREAM_NAME=stream:events:dlq
EVENT_CONSUMER_GROUP=cg:event-writers
EVENT_CONSUMER_NAME=worker-1
BATCH_SIZE=100
EVENT_CLAIM_MIN_IDLE_MS=60000
EVENT_MAX_DELIVERIES=5
EVENT_STREAM_MAXLEN=1000000
EVENT_DLQ_MAXLEN=100000
MAX_REQUEST_BODY_BYTES=262144

# Rate limiting (sliding window, requests per window)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_IP=120
RATE_LIMIT_USER=300
RATE_LIMIT_EVENTS=600

# Cache TTLs (seconds)
CACHE_TTL_DAU=300
CACHE_TTL_FUNNEL=300
CACHE_TTL_RETENTION=600
CACHE_TTL_REALTIME=30
IDEM_TTL_SECONDS=86400

# Seed accounts (dev only)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ANALYST_EMAIL=analyst@example.com
SEED_ANALYST_PASSWORD=Analyst123!
SEED_CLIENT_EMAIL=client@example.com
SEED_CLIENT_PASSWORD=Client123!
